    {
      "cell_type": "code",
      "source": [
        "#Hyperparameter Tuning using Randomised Search\n",
        "from sklearn.model_selection import RandomizedSearchCV"
      ],
      "metadata": {
        "id": "zIJqfNwOcuSh"
      },
      "execution_count": 76,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "param_dist = {\n",
        "    'n_estimators': [100, 200, 300],\n",
        "    'max_depth': [10, 20, 30, None],\n",
        "    'min_samples_split': [2, 5, 10],\n",
        "    'min_samples_leaf': [1, 2, 4],\n",
        "    'max_features': ['sqrt', 'log2'],\n",
        "    'bootstrap': [True, False]\n",
        "}"
      ],
      "metadata": {
        "id": "i2xLnmUvdPfo"
      },
      "execution_count": 77,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rf = RandomForestClassifier(random_state=42)"
      ],
      "metadata": {
        "id": "xTTXilZadScg"
      },
      "execution_count": 78,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "random_search = RandomizedSearchCV(\n",
        "    estimator=rf,\n",
        "    param_distributions=param_dist,\n",
        "    n_iter=10,          # reduce from 20 or 50\n",
        "    cv=3,               # reduce from 5\n",
        "    scoring='accuracy',\n",
        "    n_jobs=-1,          # use all CPU cores\n",
        "    random_state=42,\n",
        "    verbose=2\n",
        ")"
      ],
      "metadata": {
        "id": "wZ1yCx4RdUEE"
      },
      "execution_count": 84,
      "outputs": []
    },
