    {
      "cell_type": "code",
      "source": [
        "numeric_cols = [\n",
        "    'age_years',\n",
        "    'ssc_percentage',\n",
        "    'hsc_percentage',\n",
        "    'degree_percentage',\n",
        "    'technical_score',\n",
        "    'aptitude_score',\n",
        "    'communication_score',\n",
        "    'skills_match_percentage',\n",
        "    'certifications_count',\n",
        "    'years_of_experience',\n",
        "    'previous_ctc_lpa',\n",
        "    'expected_ctc_lpa',\n",
        "    'notice_period_days',\n",
        "    'employment_gap_months'\n",
        "]"
      ],
