    {
      "cell_type": "code",
      "source": [
        "#ENCODING\n",
        "#1. Label Encoding (Binary variables)\n",
        "binary_cols = [\n",
        "    'gender',\n",
        "    'internship_experience',\n",
        "    'career_switch_willingness',\n",
        "    'relevant_experience',\n",
        "    'bond_requirement',\n",
        "    'layoff_history',\n",
        "    'relocation_willingness',\n",
        "    'status'\n",
        "]"
      ],
      "metadata": {
        "id": "nlzpGXUkLgss"
      },
      "execution_count": 24,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "le = LabelEncoder()\n",
        "\n",
        "for col in binary_cols:\n",
        "    df[col] = le.fit_transform(df[col])"
      ],
      "metadata": {
        "id": "zOjBYbwULnnm"
      },
      "execution_count": 23,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#2. One-Hot Encoding (Nominal variables)\n",
        "nominal_cols = [\n",
        "    'degree_specialization',\n",
        "    'company_tier',\n",
        "    'job_role_match'\n",
        "]"
      ],
      "metadata": {
        "id": "mc44kmfqLtBX"
      },
      "execution_count": 25,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df = pd.get_dummies(\n",
        "    df,\n",
        "    columns=nominal_cols,\n",
        "    drop_first=True\n",
        ")"
      ],
      "metadata": {
        "id": "IACT7DH7L1ly"
      },
      "execution_count": 26,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#3. Ordinal Encoding (Ordered categories)\n",
        "#competition_level (Low, Medium, High)\n",
        "competition_map = {\n",
        "    'Low': 0,\n",
        "    'Medium': 1,\n",
        "    'High': 2\n",
        "}\n",
        "\n",
        "df['competition_level'] = df['competition_level'].map(competition_map)"
      ],
      "metadata": {
        "id": "eFBoeIICMMib"
      },
      "execution_count": 27,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#skill_match (Low, Medium, High)\n",
        "skill_map = {\n",
        "    'Low': 0,\n",
        "    'Medium': 1,\n",
        "    'High': 2\n",
        "}\n",
        "\n",
        "df['skill_match'] = df['skill_match'].map(skill_map)"
      ],
      "metadata": {
        "id": "fc74vsOYMN3l"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Experience_Match (Fresher, Junior, Mid)\n",
        "df['years_of_experience'] = df['years_of_experience'].map({\n",
        "    'Fresher': 0,\n",
        "    'Junior': 1,\n",
        "    'Mid': 2\n",
        "})"
      ],
      "metadata": {
        "id": "SxMBFjxeO3ML"
      },
      "execution_count": 35,
      "outputs": []
    },
