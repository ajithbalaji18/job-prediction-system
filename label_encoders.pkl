      "cell_type": "code",
      "source": [
        "#Evaluate:\n",
        "print(\"Accuracy :\", accuracy_score(y_test, y_pred_dt))\n",
        "print(\"Precision:\", precision_score(y_test, y_pred_dt))\n",
        "print(\"Recall   :\", recall_score(y_test, y_pred_dt))\n",
        "print(\"F1 Score :\", f1_score(y_test, y_pred_dt))"
      ],
      "metadata": {
