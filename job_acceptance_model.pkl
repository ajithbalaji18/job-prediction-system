,"\n","bond_requirement\n","['Not Required' 'Required']\n","\n","layoff_history\n","['No' 'Yes']\n","\n","relocation_willingness\n","['Not Willing' 'Willing']\n","\n","status\n","['Not Placed' 'Placed']\n"]}]},{"cell_type":"code","source":["#Binary Encoding\n","# Gender\n","df['gender'] = df['gender'].map({\n","    'Male': 1,\n","    'Female': 0\n","})\n","\n","# Internship Experience\n","df['internship_experience'] = df['internship_experience'].map({\n","    'Yes': 1,\n","    'No': 0\n","})\n","\n","# Career Switch Willingness\n","df['career_switch_willingness'] = df['career_switch_willingness'].map({\n","    'Willing': 1,\n","    'Not Willing': 0\n","})\n","\n","# Relevant Experience\n","df['relevant_experience'] = df['relevant_experience'].map({\n","    'Relevant': 1,\n","    'Not Relevant': 0\n","})\n","\n","# Job Role Match\n","df['job_role_match'] = df['job_role_match'].map({\n","    'Matched': 1,\n","    'Not Matched': 0\n","})\n","\n","# Bond Requirement\n","df['bond_requirement'] = df['bond_requirement'].map({\n","    'Required': 1,\n","    'Not Required': 0\n","})\n","\n","# Layoff History\n","df['layoff_history'] = df['layoff_history'].map({\n","    'Yes': 1,\n","    'No': 0\n","})\n","\n","# Relocation Willingness\n","df['relocation_willingness'] = df['relocation_willingness'].map({\n","    'Willing': 1,\n","    'Not Willing': 0\n","})\n","\n","# Target Variable\n","df['status'] = df['status'].map({\n","    'Placed': 1,\n","    'Not Placed': 0\n","})"],"metadata":{"id":"0XJibv-jvhtl","executionInfo":{"status":"ok","timestamp":1781870255811,"user_tz":-330,"elapsed":41,"user":{"displayName":"Ajith Balaji R","userId":"09038294931466871982"}}},"execution_count":39,"outputs":[]},{"cell_type":"code","source":["#Ordinal Encoding\n","#Company Tier\n","df['company_tier'] = df['company_tier'].map({\n","    'Tier 1': 3,\n","    'Tier 2': 2,\n","    'Tier 3': 1\n","})"],"metadata":{"id":"i6CV9vJ3vswn","executionInfo":{"status":"ok","timestamp":1781870295733,"user_tz